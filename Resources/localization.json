      "zh": "最终生成的 MP4 视频会保存到这里。"
    },
    {
      "key": "chartRenderWidth",
      "en": "Video width",
      "zh": "视频宽度"
    },
    {
      "key": "chartRenderWidthHint",
      "en": "Horizontal resolution. Higher values are sharper but slower and create larger files.",
      "zh": "横向分辨率。越大越清晰，但渲染更慢、文件更大。"
    },
    {
      "key": "chartRenderHeight",
      "en": "Video height",
      "zh": "视频高度"
    },
    {
      "key": "chartRenderHeightHint",
      "en": "Vertical resolution. 1080 is recommended for most uploads.",
      "zh": "纵向分辨率。普通投稿推荐 1080。"
    },
    {
      "key": "chartRenderFps",
      "en": "Frame rate",
      "zh": "帧率"
    },
    {
      "key": "chartRenderFpsHint",
      "en": "Frames per second. 60 fps is smooth and recommended.",
      "zh": "每秒画面数量。60 帧已经很流畅，推荐保持默认。"
    },
    {
      "key": "chartRenderCrf",
      "en": "Quality parameter",
      "zh": "画质参数"
    },
    {
      "key": "chartRenderCrfHint",
      "en": "Advanced x264/NVENC quality value. Lower means clearer video and larger files.",
      "zh": "高级画质参数。数值越低越清晰、文件越大。看不懂就保持默认。"
    },
    {
      "key": "chartRenderPreset",
      "en": "Encoder mode",
      "zh": "编码方式"
    },
    {
      "key": "chartRenderPresetHint",
      "en": "Default uses GPU encoding when available. Use cpu only when GPU encoding fails.",
      "zh": "默认会优先使用 GPU 硬编码。只有 GPU 编码出问题时才建议填 cpu。"
    },
    {
      "key": "chartRenderProfileHint",
      "en": "Changes apply to the next render immediately. Lower CRF means higher quality and larger files.",
      "zh": "修改后下一次渲染立即生效。CRF 越低画质越高、文件越大。"
    },
    {
      "key": "chartRenderBasicHint",
      "en": "Recommended default: 1080p, 60 fps, GPU encoding when available.",
      "zh": "推荐默认：1080p、60 帧，并在可用时优先使用 GPU 硬编码。"
    },
    {
      "key": "chartRenderAdvancedHint",
      "en": "Advanced settings are only needed for troubleshooting or special export requirements.",
      "zh": "高级设置只适合排查问题或有特殊导出需求时使用。"
    },
    {
      "key": "chartRenderShowAdvanced",
